DATABASE_URL="postgresql://user:pass@host:5432/db"
PORT=3000
REDIS_URL="redis://localhost:6379"

# JWT (obligatorio en producción)
JWT_SECRET="cambiar-por-secreto-largo"
JWT_EXPIRES_IN="7d"

# Google OAuth (opcional; si falta, no se registran las rutas /auth/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Facebook OAuth (opcional)
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:3000/auth/facebook/callback"

# Primer administrador (opcional). Con email + contraseña (≥8) el seed crea usuario + rol SUPER_ADMIN sin usar la API.
# Si el usuario ya existe (p. ej. tras POST /auth/register), solo se asigna el rol.
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_ADMIN_FIRST_NAME=""
BOOTSTRAP_ADMIN_LAST_NAME=""
